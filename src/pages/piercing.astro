---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { siteConfig } from '../data/siteConfig';
import { piercings, piercingCategories } from '../data/piercings';

// Redirect if piercing is disabled
if (!siteConfig.showPiercing) {
  return Astro.redirect('/');
}

const whatsappMsg = 'Olá, gostei de um piercing que vi no site. Pode me passar um orçamento?';
const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsapp}?text=${encodeURIComponent(whatsappMsg)}`;
---

<BaseLayout title="Piercings" description="Galeria de piercings do Noir Ink Studio com materiais certificados.">

  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <p class="section-label">Serviços</p>
      <h1>Piercings</h1>
      <div class="gold-line"></div>
      <p class="page-header-sub">
        Materiais certificados, técnica segura e estética premium.
        Cada piercing é realizado com cuidado e atenção total à sua saúde e satisfação.
      </p>
    </div>
    <div class="header-bg">
      <img src="https://images.unsplash.com/photo-1588444837495-c6cfeb53f32d?w=1400&q=80" alt="" loading="eager" />
      <div class="header-overlay"></div>
    </div>
  </div>

  <!-- Gallery -->
  <section class="section piercing-section">
    <div class="container">
      <!-- Filter Tabs -->
      <div class="filter-tabs">
        <button class="filter-tab active" data-filter="all">Todos</button>
        {piercingCategories.map(cat => (
          <button class="filter-tab" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- Piercing Grid -->
      <div class="gallery-grid" id="piercing-gallery">
        {piercings.map(p => (
          <div
            class="gallery-item"
            data-category={p.category}
            data-title={p.title}
            data-description={p.description}
            data-note={p.clientNote}
            data-image={p.image}
            data-healing={p.healingTime}
            role="button"
            tabindex="0"
            aria-label={`Ver detalhes: ${p.title}`}
          >
            <img src={p.image} alt={p.title} loading="lazy" />
            <div class="gallery-item-overlay">
              <p class="item-category">{p.category}</p>
              <p class="item-title">{p.title}</p>
              <p class="item-healing">⏱ {p.healingTime}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="section piercing-info">
    <div class="container">
      <SectionTitle
        label="Segurança"
        title="Nosso Compromisso"
        align="center"
        subtitle="Todos os piercings são realizados com os mais altos padrões de higiene e segurança."
      />
      <div class="info-grid">
        {[
          { icon: '🛡️', title: 'Materiais Certificados', text: 'Aço cirúrgico 316L, titânio anodizado e ouro 14k. Materiais biocompatíveis e de alta qualidade.' },
          { icon: '🔬', title: 'Esterilização Rigorosa', text: 'Autoclave certificada, materiais descartáveis e ambiente higienizado a cada procedimento.' },
          { icon: '📋', title: 'Orientação Completa', text: 'Receba um manual de cuidados pós-piercing e tire todas as suas dúvidas com nossos especialistas.' },
          { icon: '❤️', title: 'Acompanhamento', text: 'Estamos disponíveis para acompanhar sua cicatrização e esclarecer dúvidas durante o processo.' },
        ].map(item => (
          <div class="info-card">
            <span class="info-icon">{item.icon}</span>
            <h4 class="info-title">{item.title}</h4>
            <p class="info-text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Budget CTA -->
  <section class="budget-cta">
    <div class="container cta-row">
      <div>
        <h3>Tem interesse em um piercing?</h3>
        <p>Entre em contato e agende sua consulta gratuita.</p>
      </div>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn--gold">
        Solicitar Orçamento
      </a>
    </div>
  </section>

  <!-- Contact -->
  <ContactSection />

  <!-- Floating WA -->
  <WhatsAppButton message={whatsappMsg} />

  <!-- Piercing Modal -->
  <div class="modal-backdrop" id="piercing-modal" role="dialog" aria-modal="true">
    <button class="modal-close" id="p-modal-close" aria-label="Fechar">✕</button>
    <div class="modal">
      <div class="modal-image">
        <img src="" alt="" id="p-modal-img" loading="lazy" />
      </div>
      <div class="modal-content">
        <div>
          <p class="section-label" id="p-modal-category"></p>
          <h3 id="p-modal-title" style="margin-top: 0.5rem;"></h3>
          <div class="gold-line" style="margin: 1rem 0;"></div>
          <p id="p-modal-description" style="color: var(--gray-4); font-size: 0.95rem;"></p>
          <p class="healing-time" id="p-modal-healing"></p>
        </div>
        <blockquote class="modal-quote">
          <p id="p-modal-note"></p>
        </blockquote>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Pedir orçamento pelo WhatsApp
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Filter tabs
  const tabs = document.querySelectorAll('#piercing-gallery ~ * .filter-tab, .filter-tab');
  const items = document.querySelectorAll('#piercing-gallery .gallery-item');
  const allTabs = document.querySelectorAll('.filter-tab');

  allTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = tab.getAttribute('data-filter');
      allTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      items.forEach(item => {
        const cat = item.getAttribute('data-category');
        (item as HTMLElement).style.display = (filter === 'all' || cat === filter) ? 'block' : 'none';
      });
    });
  });

  // Modal
  const modal = document.getElementById('piercing-modal')!;
  const closeBtn = document.getElementById('p-modal-close')!;

  items.forEach(item => {
    const open = () => {
      document.getElementById('p-modal-img')!.setAttribute('src', item.getAttribute('data-image') || '');
      document.getElementById('p-modal-img')!.setAttribute('alt', item.getAttribute('data-title') || '');
      document.getElementById('p-modal-title')!.textContent = item.getAttribute('data-title');
      document.getElementById('p-modal-category')!.textContent = item.getAttribute('data-category');
      document.getElementById('p-modal-description')!.textContent = item.getAttribute('data-description');
      document.getElementById('p-modal-note')!.textContent = item.getAttribute('data-note');
      const healingEl = document.getElementById('p-modal-healing')!;
      healingEl.textContent = `⏱ Cicatrização: ${item.getAttribute('data-healing')}`;
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    item.addEventListener('click', open);
    item.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') open(); });
  });

  closeBtn.addEventListener('click', () => { modal.classList.remove('active'); document.body.style.overflow = ''; });
  modal.addEventListener('click', (e) => { if (e.target === modal) { modal.classList.remove('active'); document.body.style.overflow = ''; } });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { modal.classList.remove('active'); document.body.style.overflow = ''; } });
</script>

<style>
  .page-header {
    position: relative;
    padding: 12rem 0 6rem;
    overflow: hidden;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .header-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%);
  }

  .header-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(8,8,8,0.97) 0%, rgba(8,8,8,0.8) 60%, rgba(8,8,8,0.6) 100%);
  }

  .page-header .container { position: relative; z-index: 1; }

  .page-header-sub {
    color: var(--gray-4);
    font-style: italic;
    font-size: 1rem;
    max-width: 55ch;
    margin-top: 0.5rem;
  }

  .piercing-section { background: var(--black); }

  .item-category {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }

  .item-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--white);
  }

  .item-healing {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--gray-3);
    margin-top: 0.3rem;
  }

  .healing-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--gold);
    margin-top: 1rem;
    max-width: none;
  }

  /* Info section */
  .piercing-info { background: var(--black-2); }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .info-card {
    background: var(--black-3);
    border: 1px solid var(--gray-1);
    padding: 2rem;
    transition: var(--transition);
  }

  .info-card:hover {
    border-color: var(--gold-dark);
    transform: translateY(-4px);
  }

  .info-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }

  .info-title {
    font-size: 1.1rem;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .info-text {
    font-size: 0.875rem;
    color: var(--gray-4);
    line-height: 1.7;
    max-width: none;
  }

  /* Budget CTA */
  .budget-cta {
    background: var(--black-2);
    border-top: 1px solid var(--gray-1);
    border-bottom: 1px solid var(--gray-1);
    padding: 3rem 0;
  }

  .cta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-row h3 { font-size: 1.8rem; margin-bottom: 0.3rem; }
  .cta-row p { color: var(--gray-4); font-style: italic; max-width: none; }

  .modal-quote {
    border-left: 2px solid var(--gold-dark);
    padding-left: 1rem;
  }

  .modal-quote p {
    font-style: italic;
    font-size: 0.95rem;
    color: var(--gray-4);
    max-width: none;
  }
</style>
