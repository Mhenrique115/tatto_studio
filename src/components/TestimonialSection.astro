---
import { testimonials } from '../data/testimonials';
import SectionTitle from './SectionTitle.astro';
---

<section class="section testimonials-section" id="depoimentos">
  <div class="container">
    <SectionTitle
      label="Depoimentos"
      title="O que dizem nossos clientes"
      align="center"
    />

    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card" style={`animation-delay: ${i * 0.1}s`}>
          <div class="stars">
            {Array.from({ length: t.rating }).map(() => <span>★</span>)}
          </div>
          <p class="testimonial-text">"{t.text}"</p>
          <div class="testimonial-author">
            <img src={t.avatar} alt={t.name} loading="lazy" />
            <div>
              <p class="author-name">{t.name}</p>
              <p class="author-detail">{t.tattooStyle} · {t.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section { background: var(--black-2); }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .testimonial-card {
    background: var(--black-3);
    border: 1px solid var(--gray-1);
    padding: 2rem;
    transition: var(--transition);
    position: relative;
  }

  .testimonial-card::before {
    content: '"';
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    font-family: var(--font-display);
    font-size: 5rem;
    color: var(--gold-dark);
    opacity: 0.3;
    line-height: 1;
  }

  .testimonial-card:hover {
    border-color: var(--gold-dark);
    transform: translateY(-4px);
    box-shadow: var(--shadow-gold);
  }

  .stars {
    color: var(--gold);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .testimonial-text {
    color: var(--gray-4);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--gray-1);
  }

  .testimonial-author img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--gold-dark);
  }

  .author-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--white);
    max-width: none;
    line-height: 1.3;
  }

  .author-detail {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--gold);
    max-width: none;
  }
</style>
