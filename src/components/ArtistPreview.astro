---
import { artist } from '../data/artist';
import SectionTitle from './SectionTitle.astro';
import { withBase } from '../utils/basePath';
---

<section class="section artist-preview bg-texture" id="artista">
  <div class="container">
    <div class="artist-grid">
      <div class="artist-image-col">
        <div class="artist-image-frame">
          <img src={artist.photo} alt={artist.name} loading="lazy" />
          <div class="image-decoration"></div>
        </div>
        <div class="artist-badge">
          {artist.achievements.slice(0, 3).map(a => (
            <div class="badge-item">
              <span class="badge-dot">✦</span>
              <span>{a}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="artist-info-col">
        <SectionTitle
          label="Conheça o Artista"
          title={artist.name}
          subtitle={artist.role}
        />

        <blockquote class="artist-quote">
          <p>"{artist.quote}"</p>
          <cite>— {artist.nickname}</cite>
        </blockquote>

        <p class="artist-bio-preview">
          {artist.bio.split('\n\n')[0]}
        </p>

        <div class="specialties-preview">
          <p class="spec-label">Especialidades</p>
          <div class="spec-tags">
            {artist.specialties.map(s => (
              <span class="spec-tag">{s.icon} {s.name}</span>
            ))}
          </div>
        </div>

        <div class="artist-actions">
          <a href={withBase('/artista')} class="btn btn--gold">Ver Perfil Completo</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .artist-preview {
    background: var(--black-2);
  }

  .artist-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  .artist-image-col {
    position: relative;
  }

  .artist-image-frame {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .artist-image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: filter 0.5s ease;
  }

  .artist-image-frame:hover img {
    filter: grayscale(0%);
  }

  .image-decoration {
    position: absolute;
    inset: -8px;
    border: 1px solid var(--gold-dark);
    pointer-events: none;
    transform: translate(8px, 8px);
  }

  .artist-badge {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    background: var(--black-3);
    border: 1px solid var(--gray-1);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 200px;
  }

  .badge-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--gray-4);
  }

  .badge-dot { color: var(--gold); font-size: 0.5rem; }

  .artist-quote {
    border-left: 2px solid var(--gold);
    padding-left: 1.5rem;
    margin: 1.5rem 0 2rem;
  }

  .artist-quote p {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--white-dim);
    max-width: none;
  }

  .artist-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--gold);
    font-style: normal;
  }

  .artist-bio-preview {
    color: var(--gray-4);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .specialties-preview { margin-bottom: 2.5rem; }

  .spec-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-3);
    margin-bottom: 0.75rem;
  }

  .spec-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .spec-tag {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--gray-1);
    font-size: 0.85rem;
    color: var(--gray-4);
    transition: var(--transition);
  }

  .spec-tag:hover {
    border-color: var(--gold-dark);
    color: var(--white);
  }

  @media (max-width: 900px) {
    .artist-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .artist-badge {
      bottom: -1rem;
      right: 0;
    }
  }
</style>
