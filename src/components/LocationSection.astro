---
import { siteConfig } from '../data/siteConfig';
import SectionTitle from './SectionTitle.astro';
---

<section class="section location-section" id="localizacao">
  <div class="container">
    <SectionTitle
      label="Onde Estamos"
      title="Localização"
      subtitle={`${siteConfig.address.street}, ${siteConfig.address.neighborhood} — ${siteConfig.address.city}/${siteConfig.address.state}`}
    />

    <div class="location-grid">
      <div class="map-wrapper">
        <iframe
          src={siteConfig.address.mapEmbedUrl}
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen={false}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Localização do estúdio"
        ></iframe>
      </div>

      <div class="location-info">
        <div class="info-card">
          <div class="info-icon">📍</div>
          <div>
            <p class="info-label">Endereço</p>
            <p class="info-text">{siteConfig.address.street}</p>
            <p class="info-text">{siteConfig.address.neighborhood}, {siteConfig.address.city} — {siteConfig.address.state}</p>
            <p class="info-text">{siteConfig.address.cep}</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">🔖</div>
          <div>
            <p class="info-label">Referência</p>
            <p class="info-text">{siteConfig.address.reference}</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">⏰</div>
          <div>
            <p class="info-label">Horários Principais</p>
            <p class="info-text">Seg–Sex: 10h às 20h</p>
            <p class="info-text">Sábado: 10h às 18h</p>
            <p class="info-text">Domingo: Fechado</p>
          </div>
        </div>

        <a
          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(siteConfig.address.street + ', ' + siteConfig.address.neighborhood + ', ' + siteConfig.address.city)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline"
        >
          Abrir no Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .location-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .map-wrapper {
    overflow: hidden;
    border: 1px solid var(--gray-1);
    filter: grayscale(60%) contrast(1.1);
    transition: filter 0.4s ease;
  }

  .map-wrapper:hover { filter: grayscale(0%); }

  .location-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--black-3);
    border: 1px solid var(--gray-1);
    transition: var(--transition);
  }

  .info-card:hover { border-color: var(--gold-dark); }

  .info-icon { font-size: 1.25rem; flex-shrink: 0; margin-top: 0.1rem; }

  .info-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .info-text {
    font-size: 0.9rem;
    color: var(--gray-4);
    max-width: none;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .location-grid { grid-template-columns: 1fr; }
  }
</style>
