---
import { siteConfig } from '../data/siteConfig';
---

<!-- Modal (shared, JS-controlled) -->
<div class="modal-backdrop" id="gallery-modal" role="dialog" aria-modal="true" aria-label="Detalhes da arte">
  <button class="modal-close" id="modal-close" aria-label="Fechar">✕</button>
  <div class="modal">
    <div class="modal-image">
      <img src="" alt="" id="modal-img" loading="lazy" />
    </div>
    <div class="modal-content">
      <div>
        <p class="section-label" id="modal-category">Categoria</p>
        <h3 id="modal-title" style="margin-top: 0.5rem;"></h3>
        <div class="gold-line" style="margin: 1rem 0;"></div>
        <p id="modal-description" style="color: var(--gray-4); font-size: 0.95rem;"></p>
      </div>

      <blockquote class="modal-quote" id="modal-quote">
        <p id="modal-client-note"></p>
      </blockquote>

      <a
        href="#"
        id="modal-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--whatsapp"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Pedir orçamento pelo WhatsApp
      </a>
    </div>
  </div>
</div>

<script define:vars={{ whatsapp: siteConfig.contact.whatsapp }}>
  const modal = document.getElementById('gallery-modal');
  const closeBtn = document.getElementById('modal-close');

  function openModal(data) {
    const msg = encodeURIComponent('Olá, gostei desta tatuagem. Pode me passar um orçamento com base nessa referência?');
    document.getElementById('modal-img').src = data.image;
    document.getElementById('modal-img').alt = data.title;
    document.getElementById('modal-title').textContent = data.title;
    document.getElementById('modal-category').textContent = data.category;
    document.getElementById('modal-description').textContent = data.description;
    document.getElementById('modal-client-note').textContent = data.clientNote || data.note || '';
    document.getElementById('modal-whatsapp').href = `https://wa.me/${whatsapp}?text=${msg}`;
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('active');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Expose globally
  window.openGalleryModal = openModal;
</script>

<style>
  .modal-quote {
    border-left: 2px solid var(--gold-dark);
    padding-left: 1rem;
  }

  .modal-quote p {
    font-style: italic;
    font-size: 0.95rem;
    color: var(--gray-4);
    max-width: none;
  }
</style>
