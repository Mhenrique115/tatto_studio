---
import { siteConfig } from '../data/siteConfig';
import { withBase } from '../utils/basePath';

interface Props {
  title?: string;
  subtitle?: string;
  image?: string;
  showCta?: boolean;
}

const {
  title = siteConfig.name,
  subtitle = siteConfig.tagline,
  image = 'https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=1600&q=80',
  showCta = true,
} = Astro.props;

const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsapp}?text=${encodeURIComponent('Olá! Quero agendar uma tatuagem.')}`;
---

<section class="hero">
  <div class="hero-bg">
    <img src={image} alt="Noir Ink Studio" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-inner">
      <p class="section-label hero-label">Belo Horizonte, MG</p>
      <h1 class="hero-title">{title}</h1>
      <div class="gold-line"></div>
      <p class="hero-subtitle">{subtitle}</p>
      {showCta && (
        <div class="hero-actions">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn--gold">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Agendar pelo WhatsApp
          </a>
          <a href={withBase('/artes')} class="btn btn--outline">Ver Galeria</a>
        </div>
      )}
    </div>

    <div class="hero-scroll">
      <span class="scroll-text">Rolar</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: slowZoom 20s ease-in-out infinite alternate;
  }

  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 8, 1) 0%,
      rgba(8, 8, 8, 0.75) 40%,
      rgba(8, 8, 8, 0.3) 70%,
      rgba(8, 8, 8, 0.1) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-inner {
    max-width: 800px;
  }

  .hero-label {
    margin-bottom: 1.5rem;
    animation: fadeUp 1s ease forwards;
    opacity: 0;
  }

  .hero-title {
    color: var(--white);
    animation: fadeUp 1s ease 0.15s forwards;
    opacity: 0;
  }

  .gold-line {
    animation: fadeUp 1s ease 0.3s forwards;
    opacity: 0;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--white-dim);
    font-style: italic;
    max-width: 50ch;
    animation: fadeUp 1s ease 0.45s forwards;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
    animation: fadeUp 1s ease 0.6s forwards;
    opacity: 0;
  }

  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 1rem;
    align-self: flex-end;
    animation: fadeIn 1s ease 1s forwards;
    opacity: 0;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gray-3);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @media (max-width: 768px) {
    .hero { padding-bottom: 3rem; }
    .hero-scroll { display: none; }
  }
</style>
