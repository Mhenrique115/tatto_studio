---
import { siteConfig } from '../data/siteConfig';
import SectionTitle from './SectionTitle.astro';

const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsapp}?text=${encodeURIComponent('Olá! Quero agendar uma tatuagem.')}`;
---

<section class="section contact-section" id="contato">
  <div class="container">
    <div class="contact-grid">
      <div>
        <SectionTitle
          label="Fale Conosco"
          title="Contato"
          subtitle="Estamos prontos para transformar sua ideia em arte."
        />

        <div class="contact-items">
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
            </div>
            <div>
              <p class="contact-label">WhatsApp</p>
              <a href={whatsappUrl} target="_blank" class="contact-value">{siteConfig.contact.whatsappDisplay}</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
            <div>
              <p class="contact-label">Instagram</p>
              <a href={siteConfig.contact.instagramUrl} target="_blank" class="contact-value">{siteConfig.contact.instagram}</a>
            </div>
          </div>

          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div>
              <p class="contact-label">E-mail</p>
              <a href={`mailto:${siteConfig.contact.email}`} class="contact-value">{siteConfig.contact.email}</a>
            </div>
          </div>
        </div>
      </div>

      <div class="hours-card">
        <h3 class="hours-title">Horário de<br/>Funcionamento</h3>
        <div class="gold-line"></div>
        <ul class="hours-list">
          {siteConfig.hours.map(h => (
            <li class:list={['hours-item', { 'is-closed': h.time === 'Fechado' }]}>
              <span class="hours-day">{h.day}</span>
              <span class="hours-time">{h.time}</span>
            </li>
          ))}
        </ul>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn--gold" style="margin-top: 2rem; width: 100%; justify-content: center;">
          Fazer Reserva
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section { background: var(--black-2); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    border: 1px solid var(--gray-1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
    transition: var(--transition);
  }

  .contact-item:hover .contact-icon {
    border-color: var(--gold);
    background: var(--gold-glow);
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-3);
    margin-bottom: 0.2rem;
  }

  .contact-value {
    color: var(--white);
    font-size: 1rem;
    transition: var(--transition);
  }

  .contact-value:hover { color: var(--gold); }

  .hours-card {
    background: var(--black-3);
    border: 1px solid var(--gray-1);
    padding: 2.5rem;
  }

  .hours-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.15;
    margin-bottom: 0;
  }

  .hours-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .hours-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--gray-1);
    font-size: 0.9rem;
  }

  .hours-day { color: var(--gray-4); }
  .hours-time { color: var(--white); font-weight: 600; }
  .is-closed .hours-time { color: var(--gray-2); }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
