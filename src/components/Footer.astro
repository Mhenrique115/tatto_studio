---
import { siteConfig } from '../data/siteConfig';
import { withBase } from '../utils/basePath';

const navLinks = [
  { label: 'Início', href: '/' },
  { label: 'Artista', href: '/artista' },
  { label: 'Artes', href: '/artes' },
  ...(siteConfig.showPiercing ? [{ label: 'Piercing', href: '/piercing' }] : []),
];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href={withBase('/')} class="footer-logo">
          <span class="logo-mark">✦</span>
          <span class="logo-text">{siteConfig.name}</span>
        </a>
        <p class="footer-tagline">{siteConfig.tagline}</p>
        <div class="footer-socials">
          <a
            href={siteConfig.contact.instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Instagram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a
            href={`https://wa.me/${siteConfig.contact.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="WhatsApp"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="footer-col">
        <h4 class="footer-heading">Navegação</h4>
        <ul class="footer-links">
          {navLinks.map(link => (
            <li><a href={withBase(link.href)}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4 class="footer-heading">Contato</h4>
        <ul class="footer-info">
          <li>
            <span class="info-label">WhatsApp</span>
            <a href={`https://wa.me/${siteConfig.contact.whatsapp}`} target="_blank">{siteConfig.contact.whatsappDisplay}</a>
          </li>
          <li>
            <span class="info-label">Instagram</span>
            <a href={siteConfig.contact.instagramUrl} target="_blank">{siteConfig.contact.instagram}</a>
          </li>
          <li>
            <span class="info-label">E-mail</span>
            <a href={`mailto:${siteConfig.contact.email}`}>{siteConfig.contact.email}</a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div class="footer-col">
        <h4 class="footer-heading">Horários</h4>
        <ul class="footer-hours">
          {siteConfig.hours.map(h => (
            <li>
              <span class="day">{h.day.substring(0, 3)}</span>
              <span class:list={['time', { closed: h.time === 'Fechado' }]}>{h.time}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © {siteConfig.year} {siteConfig.name}. Todos os direitos reservados.
      </p>
      <p class="made-with">Arte & Código ✦</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--black-2);
    border-top: 1px solid var(--gray-1);
    padding: 5rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--gray-1);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .logo-mark { color: var(--gold); font-size: 1.1rem; }
  .logo-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
  }

  .footer-tagline {
    color: var(--gray-3);
    font-size: 0.95rem;
    font-style: italic;
    margin-bottom: 1.5rem;
    max-width: 28ch;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border: 1px solid var(--gray-1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-3);
    transition: var(--transition);
  }

  .social-link:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--gray-3);
    font-size: 0.95rem;
    transition: var(--transition);
  }

  .footer-links a:hover { color: var(--white); }

  .footer-info {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-info li { display: flex; flex-direction: column; gap: 0.2rem; }

  .info-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray-3);
  }

  .footer-info a {
    color: var(--white);
    font-size: 0.9rem;
    transition: var(--transition);
  }

  .footer-info a:hover { color: var(--gold); }

  .footer-hours {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-hours li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .day {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--gray-3);
    text-transform: uppercase;
    min-width: 32px;
  }

  .time {
    font-size: 0.85rem;
    color: var(--white);
  }

  .time.closed { color: var(--gray-3); }

  .footer-bottom {
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright, .made-with {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--gray-3);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
